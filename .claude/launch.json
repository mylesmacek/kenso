{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "kenso",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path');h.createServer((q,r)=>{let f=p.join('/Users/mylesmacek/Documents/Claude/Projects/kenso',q.url==='/'?'/index.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const m={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json'};const ext=f.split('.').pop();r.writeHead(200,{'Content-Type':m[ext]||'text/plain'});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
